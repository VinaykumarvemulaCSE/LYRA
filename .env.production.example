# ================================================================
# LYRA STYLE HUB — VERCEL ENVIRONMENT VARIABLES REFERENCE
# ================================================================
# Replace <YOUR_VALUE> with your actual credentials
# Add ALL of these to:
# Vercel Dashboard → LYRA Project → Settings → Environment Variables
# Select: Production + Preview + Development
# ================================================================

# ── FIREBASE ───────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=<YOUR_FIREBASE_API_KEY>
VITE_FIREBASE_AUTH_DOMAIN=<YOUR_PROJECT>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<YOUR_PROJECT_ID>
VITE_FIREBASE_STORAGE_BUCKET=<YOUR_PROJECT>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<YOUR_SENDER_ID>
VITE_FIREBASE_APP_ID=<YOUR_APP_ID>

# ── RAZORPAY ───────────────────────────────────────────────────
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXX
RAZORPAY_KEY_ID=rzp_test_XXXXXX
RAZORPAY_KEY_SECRET=<YOUR_RAZORPAY_SECRET>

# ── EMAIL (NODEMAILER) ─────────────────────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── GITHUB CMS ─────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_XXXXXX
GITHUB_OWNER=YourGitHubUsername
GITHUB_REPO=LYRA
GITHUB_BRANCH=master

# ── PLATFORM CONFIG ────────────────────────────────────────────
VITE_ADMIN_EMAIL=your-admin@gmail.com
